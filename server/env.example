# Copy this file to .env and fill in your real values. Never commit .env to git.

# Your OpenRouter API key — this stays on the server only.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# The port the server listens on (most hosts set this automatically).
PORT=3000

# Restrict which frontend domain is allowed to call this backend.
# Use * only while testing locally — set it to your real domain in production,
# e.g. https://barbosov-ai.vercel.app
ALLOWED_ORIGIN=*

# Fallback model if the frontend doesn't specify one.
DEFAULT_MODEL=openrouter/free
